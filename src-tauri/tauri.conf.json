{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scorecard Overlay",
  "version": "0.1.0",
  "identifier": "com.scorecard.overlay",
  "build": {
    "beforeDevCommand": "npm.cmd run dev:web",
    "beforeBuildCommand": "",
    "frontendDist": "../",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Scorecard Overlay",
        "label": "main",
        "width": 440,
        "height": 380,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": false,
        "visible": true,
        "center": false,
        "x": 24,
        "y": 24
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
